run = "git fetch origin && git reset --hard origin/main && npm install --silent 2>/dev/null && node -e \"import Database from '@replit/database';const db=new Database();const keys=await db.list('test-suite:');for(const k of keys){await db.delete(k)};console.log('Reset '+keys.length+' test suites')\" && node src/index.js"
modules = ["nodejs-20"]
[nix]
channel = "stable-24_05"

[agent]
expertMode = true

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install --silent 2>/dev/null && npm start"
waitForPort = 5000

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 30000
