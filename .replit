run = "bash scripts/sync-and-start.sh"
modules = ["nodejs-20"]
[nix]
channel = "stable-24_05"

[agent]
expertMode = true

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23636
externalPort = 3001

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/sync-and-start.sh"
waitForPort = 5000

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 30000

[deployment]
run = ["sh", "-c", "bash scripts/sync-and-start.sh"]
deploymentTarget = "autoscale"

[git]
autoCommit = false
